# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit secrets.

# From @BotFather — the token of your new bot.
BOT_TOKEN=

# Your personal Telegram chat ID (send your bot a message, then visit
# https://api.telegram.org/bot<BOT_TOKEN>/getUpdates — look for `chat.id`).
CHAT_ID=

# IANA timezone for scheduled reminders (e.g. America/New_York, Europe/London).
TIMEZONE=America/New_York

# Daily time (24hr format) to send the workout reminder.
GYM_REMINDER_TIME=11:00

# For Vercel deployment only — any random string used to authenticate cron
# invocations. Generate with: openssl rand -hex 32
CRON_SECRET=
