# --- Neon Postgres (stores time-series + OAuth tokens) ---
DATABASE_URL=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# --- NextAuth ---
AUTH_SECRET=
AUTH_TRUST_HOST=true
# bcrypt hash of your single-user login password. Generate with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
AUTH_PASSWORD_HASH=

# --- WHOOP API ---
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# --- Withings API ---
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=

# --- Cron auth (Vercel auto-injects this for configured crons) ---
CRON_SECRET=

# --- Telegram alerting (reuses existing bot) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
